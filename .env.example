# =============================================================================
# agent-hub environment configuration
# =============================================================================
# Copy to .env and fill in. .env is gitignored.
#
# Postgres password + admin token + webhook secret should be
# generated fresh per environment, e.g. with:
#   openssl rand -base64 32

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
POSTGRES_DB=agent_hub
POSTGRES_USER=agent_hub
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# Gateway admin token — used by /setup-agent-events to mint per-VM tokens.
# Lives only on the operator's Mac (NOT on agent VMs).
# -----------------------------------------------------------------------------
ADMIN_TOKEN=

# -----------------------------------------------------------------------------
# Mattermost — outbox-worker posts via the service-account PAT.
# Reuse the existing chat-emit service account where possible.
#
# MATTERMOST_TEAM_NAME (v0.1.3+) is the URL-slug of the Mattermost team that
# owns the agent-events channel. Required so the outbox-worker can resolve
# channel-name → channel-id for the REST API. Match the value in your
# Mattermost team URL (e.g., https://mattermost.litts.link/agents → "agents").
#
# MATTERMOST_DEFAULT_OUTBOX_CHANNEL is the fallback channel for curated
# events that don't carry a per-project mattermost_outbox_channel.
# -----------------------------------------------------------------------------
MATTERMOST_URL=https://mattermost.litts.link
MATTERMOST_TOKEN=
MATTERMOST_TEAM_NAME=agents
MATTERMOST_DEFAULT_OUTBOX_CHANNEL=agent-events
OUTBOX_POLL_INTERVAL_SECONDS=5

# -----------------------------------------------------------------------------
# Inbox webhook — Mattermost outgoing-webhook secret. Matches the value
# Mattermost was configured with when /setup-agent-events provisioned the
# webhook on the agent-events channel.
# -----------------------------------------------------------------------------
MATTERMOST_INBOX_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Sanitiser exempt hosts (v0.1.3 task #29).
# Comma-separated host substrings that, if they appear within a §2.1
# regex match, suppress the match. Use this to stop the gateway from
# self-blocking when its own URL legitimately appears in event payloads.
# -----------------------------------------------------------------------------
SANITISER_EXEMPT_HOSTS=10.0.5.38
